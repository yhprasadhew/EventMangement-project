generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum RsvpStatus {
  PENDING
  ACCEPTED
  DECLINED
}

model Event {
  id          String   @id @default(uuid()) @db.Uuid
  ownerUserId String
  title       String
  description String?
  location    String?

  eventDate DateTime? @map("event_date") @db.Timestamptz(6)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  invite EventInvite?
  rsvps  EventRsvp[]

  @@index([ownerUserId, createdAt(sort: Desc)], map: "idx_events_owner")
  @@map("events")
}

model EventInvite {
  id String @id @default(uuid()) @db.Uuid

  eventId String @unique @map("event_id") @db.Uuid
  token   String @unique

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  rsvps EventRsvp[]

  @@map("event_invites")
}

model EventRsvp {
  id String @id @default(uuid()) @db.Uuid

  eventId  String @map("event_id") @db.Uuid
  inviteId String @map("invite_id") @db.Uuid

  name  String
  email String

  emailNormalized String @map("email_normalized")

  status RsvpStatus @default(PENDING)

  event  Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  invite EventInvite @relation(fields: [inviteId], references: [id], onDelete: Cascade)

  @@unique([eventId, emailNormalized])
  @@index([eventId])
  @@index([inviteId])
  @@map("event_rsvps")
}